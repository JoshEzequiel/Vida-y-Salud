        {
          "name": "Crear cliente prerequisite (principal)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{base_cliente}}/api/v1/clientes",
            "description": "Crea el cliente requerido por las pruebas de integración.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rut\": \"8{{runId}}-P\",\n  \"nombre\": \"Cliente principal {{runId}}\",\n  \"telefono\": \"+56912345678\",\n  \"email\": \"cliente.principal.{{runId}}@example.com\",\n  \"direccion\": \"Puerto Montt\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 201', () => pm.response.to.have.status(201));",
                  "pm.test('Respuesta JSON', () => pm.response.to.be.json);",
                  "const json = pm.response.json();",
                  "pm.test('Campo status = 201', () => pm.expect(json.status).to.eql(201));",
                  "pm.collectionVariables.set('clienteId', pm.response.json().data.idCliente);",
                  "pm.test('Se guardó clienteId', () => pm.expect(pm.collectionVariables.get('clienteId')).to.exist);"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
