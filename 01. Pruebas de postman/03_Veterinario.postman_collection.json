    {
      "name": "00 Preparación",
      "item": [
        {
          "name": "Health - veterinario-servicio",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_veterinario}}/actuator/health",
            "description": "Comprueba que el microservicio y su conexión a la base de datos estén activos."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const runId = Date.now().toString();",
                  "pm.collectionVariables.set('runId', runId);",
                  "const now = new Date();",
                  "const isoLocal = d => d.toISOString().slice(0, 19);",
                  "pm.collectionVariables.set('pastDate', isoLocal(new Date(now.getTime() - 60 * 60 * 1000)));",
                  "pm.collectionVariables.set('futureDate', isoLocal(new Date(now.getTime() + 30 * 24 * 60 * 60 * 1000)));",
                  "pm.collectionVariables.set('futureDate2', isoLocal(new Date(now.getTime() + 31 * 24 * 60 * 60 * 1000)));",
                  "pm.collectionVariables.set('futureBirthDate', new Date(now.getTime() + 365 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10));",
                  "pm.collectionVariables.set('pastBirthDate', '2022-05-10');",
                  "console.log('Variables inicializadas para ejecución:', runId);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "pm.test('Respuesta JSON', () => pm.response.to.be.json);",
                  "const json = pm.response.json();",
                  "pm.test('Servicio UP', () => pm.expect(json.status).to.eql('UP'));"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
